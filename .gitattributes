# Normalize all text files to LF in the repository.
# Contributors on Windows check out whatever their core.autocrlf says,
# but what lands in a commit is always LF.
* text=auto eol=lf

# --- Explicit text types ---
*.md        text eol=lf
*.mdx       text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sql       text eol=lf
*.dart      text eol=lf
*.tf        text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf
.gitignore  text eol=lf
.gitkeep    text eol=lf

# --- Binary: never diff, never normalize ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.zip       binary

# --- Lockfiles: collapse in diffs/reviews ---
pnpm-lock.yaml  -diff linguist-generated
