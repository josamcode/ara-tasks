{
  "name": "@ara/ui",
  "version": "0.0.0",
  "private": true,
  "description": "The custom component library. Every screen composes these primitives — no one-off styling.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@ara/config": "workspace:*",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "5.9.3"
  }
}
