{
  "name": "@ara/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared tsconfig / eslint / prettier configuration. Defined once, consumed by every workspace.",
  "type": "module",
  "exports": {
    "./eslint/base": "./eslint/base.js",
    "./eslint/next": "./eslint/next.js",
    "./prettier": "./prettier/index.js",
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/nest.json": "./tsconfig/nest.json",
    "./tsconfig/next.json": "./tsconfig/next.json",
    "./tsconfig/node-library.json": "./tsconfig/node-library.json",
    "./tsconfig/react-library.json": "./tsconfig/react-library.json"
  },
  "scripts": {
    "lint": "eslint ."
  },
  "dependencies": {
    "@eslint/js": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "typescript-eslint": "8.64.0"
  },
  "devDependencies": {
    "eslint": "9.39.5"
  }
}
