{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ARA Tasks — Next.js app",
  // Next compiles the app itself, so tsc is typecheck-only here (noEmit).
  // declaration/declarationMap are switched off because they are meaningless
  // without emit.
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }]
  }
}
