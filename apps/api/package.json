{
  "name": "@ara/api",
  "version": "0.0.0",
  "private": true,
  "description": "Tenant plane — NestJS modular monolith. Never shares a process or credentials with the operator plane.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
