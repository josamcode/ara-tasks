# ARA Tasks — LOCAL development environment (example)
# ---------------------------------------------------------------------------
# Copy to `.env` (git-ignored) only if you want to override the defaults below.
# The Docker Compose stack already bakes these SAME values as inline defaults
# (`${VAR:-default}`), so `docker compose up` works with NO `.env` file at all.
#
# THESE ARE NON-PRODUCTION LOCAL-ONLY VALUES. They are intentionally weak and
# safe to commit as an example. Real secrets come from the cloud secret manager
# (see CLAUDE.md rule 9 / Security Design §11) — NEVER commit a real `.env`.
# ---------------------------------------------------------------------------

# --- PostgreSQL + PostGIS (service: postgres) ---
POSTGRES_USER=ara
POSTGRES_PASSWORD=ara_local_dev_pw
POSTGRES_DB=ara_tasks
# Host port the DB is published on (container port is always 5432).
POSTGRES_PORT=5432

# --- Redis (service: redis) ---
REDIS_PORT=6379

# --- MinIO / S3-compatible object storage (service: minio) ---
# MinIO requires the root password to be >= 8 characters.
MINIO_ROOT_USER=ara_minio_local
MINIO_ROOT_PASSWORD=ara_minio_local_pw
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Default bucket the app will use for proof media (created by the app later; not
# provisioned by this stack). Documented here so the contract is visible.
S3_BUCKET=ara-proof-local

# --- Application host ports (container ports are fixed; see docker-compose.yml) ---
API_PORT=3001
WEB_PORT=3000
OPERATOR_PORT=3002

# --- Connection strings handed to the API (service DNS names on the compose network) ---
# The S0-01 scaffold does not read these yet; they are wired now as the documented
# local contract so later tickets (S0-06 config, S0-09 Drizzle) inherit them.
DATABASE_URL=postgres://ara:ara_local_dev_pw@postgres:5432/ara_tasks
REDIS_URL=redis://redis:6379
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=ara_minio_local
S3_SECRET_KEY=ara_minio_local_pw
S3_REGION=us-east-1
