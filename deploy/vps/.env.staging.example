# ARA Tasks — VPS / Coolify STAGING environment (EXAMPLE / TEMPLATE).
# =============================================================================
# PLACEHOLDERS ONLY. This file documents every variable the staging stack reads.
# It contains NO real values and MUST NOT be filled in and committed.
#
# On the VPS, set these in COOLIFY'S ENCRYPTED ENVIRONMENT for the ARA Tasks
# project (Coolify injects them into the Compose deployment at runtime). Never
# put real secrets, the VPS IP, or a real domain in Git (CLAUDE.md rule 9,
# Security Design §11). The root docker-compose.yml carries WEAK LOCAL DEFAULTS
# used only for local `docker compose` verification — every one MUST be overridden
# with a strong value in Coolify before a real deployment.
#
# `__CHANGE_ME__` = supply a strong, unique value in Coolify. Do not use the
# local-dev defaults from the repo root .env.example on the VPS.
# =============================================================================

# --- PostgreSQL + PostGIS (private; no host port on the VPS) -----------------
POSTGRES_USER=__CHANGE_ME__
POSTGRES_PASSWORD=__CHANGE_ME_STRONG_SECRET__
POSTGRES_DB=ara_tasks
# Full DSN handed to the API. MUST match POSTGRES_* above and use the internal
# service DNS name `postgres` on ara-net (NOT localhost, NOT a public host):
DATABASE_URL=postgres://__CHANGE_ME__:__CHANGE_ME_STRONG_SECRET__@postgres:5432/ara_tasks

# --- Redis (private; no host port on the VPS) --------------------------------
# Internal service DNS on ara-net:
REDIS_URL=redis://redis:6379

# --- MinIO / S3-compatible object storage (private; internal only) -----------
# MinIO root credentials — root password must be >= 8 chars.
MINIO_ROOT_USER=__CHANGE_ME__
MINIO_ROOT_PASSWORD=__CHANGE_ME_STRONG_SECRET__
# S3 client config for the API. S3_ENDPOINT uses the internal service DNS.
# Prefer a dedicated (non-root) access key/secret created inside MinIO for the app.
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=__CHANGE_ME__
S3_SECRET_KEY=__CHANGE_ME_STRONG_SECRET__
S3_BUCKET=ara-proof-staging
S3_REGION=us-east-1

# --- Local-verification host ports (IGNORED on the VPS — Coolify routes by domain).
# The staging override binds these to 127.0.0.1 only; they are never public.
# Domains for api/web/operator are assigned in the COOLIFY UI, not here.
API_PORT=3001
WEB_PORT=3000
OPERATOR_PORT=3002
MINIO_API_PORT=9000

# --- Future (later tickets; apps are scaffolds today, so these are unused now) -
# Public URLs are provided by Coolify once domains are assigned. Do NOT hardcode
# a real domain in Git — set these in Coolify's environment when the apps consume them.
# NEXT_PUBLIC_API_URL=__set_in_coolify__
# WEB_ORIGIN=__set_in_coolify__
# OPERATOR_ORIGIN=__set_in_coolify__
