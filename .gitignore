node_modules/
.pnp/
.pnp.js
.yarn/

# --- Build output ---
dist/
build/
out/
.next/
.turbo/

# Generated by `next build`; never hand-edited, so never committed.
next-env.d.ts

# --- Test / coverage ---
coverage/
.nyc_output/
playwright-report/
test-results/

# --- Environment & secrets (NEVER commit) ---
# All secrets come from the cloud secret manager. See CLAUDE.md.
.env
.env.*
!.env.example
*.pem
*.key

# --- Logs ---
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# --- Terraform (state can contain secrets) ---
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors / IDE ---
.idea/
.vscode/
